spring:
  servlet:
    multipart:
      max-file-size: 20MB
      max-request-size: 20MB
  datasource:
    url: jdbc:postgresql://localhost:5432/reimbursement
    username: postgres
    password: your-db-password
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true

app:
  jwt:
    # Generate with: openssl rand -base64 32
    secret: your-jwt-secret-at-least-32-characters-long
    expiration-ms: 86400000
  r2:
    endpoint: https://<account-id>.r2.cloudflarestorage.com
    access-key: your-r2-access-key
    secret-key: your-r2-secret-key
    bucket: receipts
  parser:
    url: http://localhost:8000

server:
  port: 8080
